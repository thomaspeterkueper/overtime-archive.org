{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overtime-archive.org/schema/ota-document.schema.json",
  "title": "Overtime Archive Document Metadata",
  "type": "object",
  "required": [
    "id",
    "title",
    "language",
    "status",
    "kg",
    "knowledge",
    "entities",
    "relations",
    "sync"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^OTA-[A-Z]+-[0-9]{4}-[0-9]{4}-[A-Z]{2}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "enum": ["de", "en"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "published", "archived"]
    },
    "kg": {
      "type": "object",
      "required": ["schema", "master", "documentId", "graphId", "system", "sourceOfTruth"],
      "properties": {
        "schema": { "type": "string" },
        "master": { "const": "kueper-knowledge-graph" },
        "documentId": { "type": "string" },
        "graphId": { "type": "string", "pattern": "^DOC:OTA:" },
        "system": { "const": "SYS:OTA:overtimearchive" },
        "sourceOfTruth": { "const": false }
      },
      "additionalProperties": false
    },
    "knowledge": {
      "type": "object",
      "required": ["domains"],
      "properties": {
        "domains": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "level", "purpose"],
            "properties": {
              "id": { "type": "string", "pattern": "^KNOW:" },
              "level": { "type": "string", "enum": ["N1", "N2", "N3", "N4"] },
              "purpose": { "type": "string", "enum": ["read", "create", "review"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "entities": {
      "type": "object",
      "required": ["mentions"],
      "properties": {
        "mentions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "relations": {
      "type": "object",
      "properties": {
        "requires": { "type": "array", "items": { "type": "string" } },
        "teaches": { "type": "array", "items": { "type": "string" } },
        "expands": { "type": "array", "items": { "type": "string" } },
        "cites": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "sync": {
      "type": "object",
      "required": ["graphVersion", "graphUpdated", "exportedFrom"],
      "properties": {
        "graphVersion": { "type": "string" },
        "graphUpdated": { "type": "string", "format": "date" },
        "exportedFrom": { "const": "kueper-knowledge-graph" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
